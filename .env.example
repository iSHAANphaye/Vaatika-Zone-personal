# MongoDB connection URI
# Local: mongodb://localhost:27017/vaatika-zone
# Cloud Atlas: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/vaatika-zone?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/vaatika-zone

# Application Port
PORT=5000

# JWT Authentication Config
JWT_SECRET=your_jwt_super_secret_key_minimum_32_characters
JWT_EXPIRES_IN=30d
